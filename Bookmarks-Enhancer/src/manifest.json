{
  "manifest_version": 3,
  "name": "Bookmarks Enhancer",
  "version": "1.0",
  "description": "Hides 'Blocked' bookmarked links. Marks bookmarked and 'Favorite' links.",
  "icons": {
    "48": "icons/highlighter-48.png",
    "96": "icons/highlighter-96.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "browser-polyfill.js",
        "utils.js",
        "contentScript.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "browser-polyfill.js",
      "utils.js",
      "backgroundScript.js"
    ]
  },
  "permissions": [
    "bookmarks",
    "storage",
    "activeTab",
    "clipboardWrite",
    "clipboardRead",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_ui": {
    "page": "options.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "Bookmarks@Enhancer",
      "strict_min_version": "121.0"
    }
  },
  "action": {
    "default_icon": "icons/highlighter-48.png",
    "default_title": "Enhance Bookmarks"
  }
}
